# ─────────────────────────────────────────────
#  Tech News Notifier — Environment Variables
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.

# ── Polling ──────────────────────────────────
# How often to check for new articles (in minutes)
POLL_INTERVAL_MINUTES=15

# Only fetch articles published within this many hours. Default: 24 (today's news).
SOURCE_MAX_AGE_HOURS=24

# ── Digest mode ───────────────────────────────
# Comma-separated hours (0–23, local time) to send digest notifications.
# Leave empty to notify every poll cycle (default behaviour).
# Example below: send at 8am and 6pm
DIGEST_HOURS=8,18

# ── Content filters ───────────────────────────
# Comma-separated keywords — articles matching any are dropped before processing.
# Case-insensitive substring match on title + excerpt.
BLOCKLIST_KEYWORDS=sponsored,deals,best buy,review roundup,giveaway,discount,coupon

# Fetch full article body for richer AI summaries (slower, more accurate).
# Set to true only if you have a fast connection and don't mind extra requests.
FETCH_FULL_ARTICLES=false

# Filter out articles from known paywalled sources (wsj.com, ft.com, bloomberg.com, nytimes.com, etc.)
FILTER_PAYWALLED_ARTICLES=false

# ── Sources (set to "false" to disable a source) ──
SOURCE_HN_ENABLED=true
SOURCE_REDDIT_PROGRAMMING_ENABLED=true
SOURCE_REDDIT_WEBDEV_ENABLED=false
SOURCE_REDDIT_JS_ENABLED=false
SOURCE_DAILYDEV_ENABLED=true
SOURCE_DEVTO_ENABLED=false
SOURCE_IEEE_ENABLED=true
SOURCE_AWS_ENABLED=true
SOURCE_TECHMEME_ENABLED=true
SOURCE_TECHCRUNCH_ENABLED=true
SOURCE_WIRED_ENABLED=false
SOURCE_ENGADGET_ENABLED=false
SOURCE_INFOQ_ENABLED=true
SOURCE_TLDR_ENABLED=true

# ── Email Notifications ───────────────────────
EMAIL_ENABLED=true

# SMTP server settings (example below is for Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# For Gmail: use an App Password (not your account password)
# https://support.google.com/accounts/answer/185833
SMTP_USER=yourname@gmail.com
SMTP_PASS=abcd efgh ijkl mnop

# Sender address
EMAIL_FROM=yourname@gmail.com

# Comma-separated list of recipient addresses
EMAIL_TO=yourname@gmail.com,teammate@company.com

# ── Slack Notifications ───────────────────────
SLACK_ENABLED=true

# Option A — Incoming Webhook (simple, no threading)
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T01AB2CDE3F/B04GH5IJK6L/xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Option B — Bot Token (enables thread replies)
# Requires a Slack app with chat:write scope and the bot added to the channel.
SLACK_BOT_TOKEN=xoxb-xxx-xxx-xxx
SLACK_CHANNEL_ID=C04ABCDE123

# Post each topic group as a thread reply under the digest intro.
# Requires SLACK_BOT_TOKEN + SLACK_CHANNEL_ID (does not work with webhook).
SLACK_USE_THREADS=true

# ── AI (optional) ─────────────────────────────
# If OPENAI_API_KEY is set, all AI features are enabled:
#   Semantic dedup, relevance scoring, trending topics, category + sentiment labels
# If not set, excerpts are used as summaries and all articles pass through.
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_MODEL=gpt-4o-mini

# Describe your role and interests — the AI uses this to score article relevance.
# When set, AI_TOPIC_FILTER is ignored (user context takes precedence).
AI_USER_CONTEXT=Senior full-stack engineer focused on TypeScript, React, Node.js, and cloud infrastructure (AWS/GCP). Interested in developer tooling, AI/ML engineering, and open source. Not interested in consumer gadgets, social media drama, or crypto.

# Fallback topic list used for relevance scoring when AI_USER_CONTEXT is not set.
# Ignored if AI_USER_CONTEXT is provided.
AI_TOPIC_FILTER=software engineering, AI/ML, cloud infrastructure, developer tools, cybersecurity, open source

# Minimum relevance score to include an article (1–10). Default: 5.
AI_RELEVANCE_THRESHOLD=5

# Minimum articles per topic group before collapsing into "Other". Default: 2.
AI_MIN_GROUP_SIZE=2

# ── Misc ──────────────────────────────────────
# Directory to persist seen-articles store and stats (defaults to ./data)
DATA_DIR=./data

# Number of days to keep seen article IDs before pruning them (default: 14)
SEEN_MAX_AGE_DAYS=14

# Log level: error | warn | info | debug
LOG_LEVEL=info
